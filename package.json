{
  "name": "management_system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:local": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "prisma generate && tsc --noEmit --incremental false",
    "typecheck:scripts": "tsc --noEmit --incremental false -p tsconfig.scripts.json",
    "check": "prisma validate && npm run typecheck && npm run typecheck:scripts && eslint app components lib scripts tests --max-warnings=0 && git diff --check",
    "cron": "tsx scripts/cron.ts",
    "postinstall": "prisma generate",
    "db:deploy": "tsx scripts/deploy-db.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:fix-roles": "tsx scripts/fix-user-roles.ts && tsx prisma/seed.ts",
    "db:backfill-project-owners": "tsx scripts/backfill-project-owners.ts",
    "db:seed-acceptance-checklists": "tsx scripts/seed-acceptance-checklists.ts",
    "db:seed-progress-reminders": "tsx scripts/seed-progress-reminder-rules.ts",
    "db:dedupe-approval-records": "tsx scripts/dedupe-approval-records.ts",
    "db:dedupe-weekly-reports": "tsx scripts/dedupe-weekly-reports.ts",
    "db:studio": "prisma studio",
    "prepare:template": "tsx scripts/prepare-reimbursement-template.ts",
    "test:e2e": "tsx scripts/run-playwright.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docxtemplater": "^3.69.0",
    "docxtemplater-image-module-free": "^1.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "node-cron": "^4.5.0",
    "pg": "^8.16.0",
    "pizzip": "^3.2.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
