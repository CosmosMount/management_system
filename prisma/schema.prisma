generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum OrderStatus {
  DRAFT
  MANAGEMENT_REVIEW
  TEACHER_REVIEW
  PENDING_APPLICANT_DOCS
  PENDING_FINANCE_REVIEW
  PENDING_APPLICANT_CONFIRM
  COMPLETED
  REJECTED
}

enum UserRoleType {
  SUPER_ADMIN
  TEAM_ADMIN
  TECH_GROUP_ADMIN
  TEACHER
  FINANCE
  PROJECT_MANAGER
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  PENDING_ACCEPTANCE
  COMPLETED
  ARCHIVED
}

enum TaskCategory {
  TEST
  ASSEMBLY
  RND
  DEBUG
  REVIEW_DRAWING
  ITERATION
}

enum Urgency {
  HIGH
  MEDIUM
  LOW
}

enum Importance {
  HIGH
  MEDIUM
  LOW
}

enum SubmissionType {
  DELIVERY
  STAGE
}

enum StageStatus {
  NOT_STARTED
  IN_PROGRESS
  PENDING_ACCEPTANCE
  COMPLETED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model User {
  id            String          @id @default(uuid())
  openId        String          @unique
  name          String
  avatar        String?
  signaturePath String?
  createdAt     DateTime        @default(now())
  orders        PurchaseOrder[]
}

model UserRole {
  id         String       @id @default(uuid())
  openId     String
  role       UserRoleType
  team       String       @default("")
  techGroup  String       @default("")

  @@unique([openId, role, team, techGroup])
}

model PurchaseOrder {
  id                String         @id @default(uuid())
  orderNo           String         @unique
  initiatorId       String
  initiator         User           @relation(fields: [initiatorId], references: [id])
  initiatorName     String
  team              String
  techGroup         String
  totalPrice        Float          @default(0)
  teamApproved      Boolean        @default(false)
  techGroupApproved Boolean        @default(false)
  invoicePaths      String         @default("[]")
  invoicePath       String?
  listDocPath       String?
  screenshotPath    String?
  status            OrderStatus    @default(DRAFT)
  rejectionReason   String?
  rejectedAt        DateTime?
  rejectedByName    String?
  lastReminderAt    DateTime?
  statusEnteredAt   DateTime       @default(now())
  items             PurchaseItem[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model PurchaseItem {
  id           String        @id @default(uuid())
  orderId      String
  order        PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name         String
  spec         String
  purchaseLink String        @default("")
  quantity     Int
  unitPrice    Float
  photoPath    String?
}

model Project {
  id            String              @id @default(uuid())
  name          String
  description   String              @default("")
  team          String
  techGroup     String
  status        ProjectStatus       @default(NOT_STARTED)
  ownerOpenId   String
  ownerName     String
  allowOwnerSelfApproval Boolean     @default(false)
  owners        ProjectOwner[]
  stages        ProjectStage[]
  tasks         Task[]
  activityLogs  ProgressActivityLog[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  archivedAt    DateTime?
  completedAt   DateTime?
  canceledAt    DateTime?
}

model ProjectOwner {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  openId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([projectId, openId])
}

model ProjectStage {
  id                  String           @id @default(uuid())
  projectId           String
  project             Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                String
  goal                String           @default("")
  sortOrder           Int
  status              StageStatus      @default(NOT_STARTED)
  evidenceUrl         String           @default("") @map("feishuDocUrl")
  ownerOpenId         String           @default("")
  ownerName           String           @default("")
  dueAt               DateTime?
  currentSubmissionId String?          @map("submissionId")
  tasks               Task[]
  submissions         TaskSubmission[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@map("ProjectMilestone")
}

model Task {
  id              String              @id @default(uuid())
  projectId       String
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId         String?
  stage           ProjectStage?       @relation(fields: [stageId], references: [id], onDelete: SetNull)
  title           String
  goal            String              @default("")
  category        TaskCategory        @default(RND)
  urgency         Urgency             @default(MEDIUM)
  importance      Importance          @default(MEDIUM)
  assigneeOpenId  String
  assigneeName    String
  assignees       TaskAssignee[]
  team            String
  techGroup       String
  metrics         String              @default("")
  dueAt           DateTime
  status          TaskStatus          @default(TODO)
  isOverdue       Boolean             @default(false)
  needsOfflineConfirmation Boolean     @default(false)
  needsWeeklyReport Boolean            @default(false)
  riskNote        String              @default("")
  riskUpdatedAt   DateTime?
  failureReason   String              @default("")
  submissions     TaskSubmission[]
  weeklyReports   WeeklyReport[]
  activityLogs    ProgressActivityLog[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  archivedAt      DateTime?
}

model TaskAssignee {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  openId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([taskId, openId])
}

model TaskSubmission {
  id            String           @id @default(uuid())
  taskId        String?
  task          Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectId     String?
  stageId       String?
  stage         ProjectStage?     @relation(fields: [stageId], references: [id], onDelete: Cascade)
  type          SubmissionType
  feishuDocUrl  String
  keyDataUrl    String           @default("") @map("videoUrl")
  note          String           @default("")
  failureReason String           @default("")
  submittedBy   String
  submitterName String
  submittedAt   DateTime         @default(now())
  approvals     ApprovalRecord[]
}

model WeeklyReport {
  id            String   @id @default(uuid())
  taskId        String
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  weekStart     DateTime
  progress      String
  risks         String   @default("")
  nextPlan      String   @default("")
  feishuDocUrl  String   @default("")
  submittedBy   String
  submitterName String
  submittedAt   DateTime @default(now())
}

model ApprovalRecord {
  id              String           @id @default(uuid())
  submissionId    String
  submission      TaskSubmission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  approverOpenId  String
  approverName    String
  approverRole    UserRoleType
  decision        ApprovalDecision
  docViewVerified Boolean          @default(false)
  offlineConfirmed Boolean         @default(false)
  comment         String           @default("")
  createdAt       DateTime         @default(now())
}

model ProgressActivityLog {
  id         String   @id @default(uuid())
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  action     String
  actorOpenId String
  actorName  String
  payload    String   @default("{}")
  createdAt  DateTime @default(now())
}

model Feedback {
  id              String            @id @default(uuid())
  submitterOpenId String
  submitterName   String
  status          FeedbackStatus    @default(OPEN)
  lastMessageAt   DateTime          @default(now())
  closedAt        DateTime?
  messages        FeedbackMessage[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([submitterOpenId])
  @@index([status, lastMessageAt])
}

model FeedbackMessage {
  id           String               @id @default(uuid())
  feedbackId   String
  feedback     Feedback             @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  authorOpenId String
  authorName   String
  body         String               @default("")
  attachments  FeedbackAttachment[]
  createdAt    DateTime             @default(now())

  @@index([feedbackId, createdAt])
}

model FeedbackAttachment {
  id        String          @id @default(uuid())
  messageId String
  message   FeedbackMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  path      String
  fileName  String
  mimeType  String
  size      Int
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
}
