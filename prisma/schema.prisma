generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  DRAFT
  MANAGEMENT_REVIEW
  TEACHER_REVIEW
  PENDING_APPLICANT_DOCS
  PENDING_FINANCE_REVIEW
  PENDING_APPLICANT_CONFIRM
  COMPLETED
  REJECTED
}

enum UserRoleType {
  SUPER_ADMIN
  TEAM_ADMIN
  TECH_GROUP_ADMIN
  TEACHER
  FINANCE
  PROJECT_MANAGER
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  PENDING_ACCEPTANCE
  COMPLETED
  ARCHIVED
  PROJECT_CANCELED
}

enum TaskDeletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskCreationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectDdlChangeRequestType {
  CASCADE_EXTENSION
  SINGLE_STAGE_ADJUSTMENT
}

enum ProjectDdlChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskDdlChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskRiskStatus {
  ACTIVE
  RESOLVED
}

enum TaskRiskSource {
  MANUAL
  WEEKLY
}

enum Urgency {
  HIGH
  MEDIUM
  LOW
}

enum Importance {
  HIGH
  MEDIUM
  LOW
}

enum SubmissionType {
  DELIVERY
  STAGE
}

enum StageStatus {
  NOT_STARTED
  IN_PROGRESS
  PENDING_ACCEPTANCE
  COMPLETED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum FileAssetKind {
  ORDER_ATTACHMENT
  ORDER_ITEM_IMAGE
  FEEDBACK_ATTACHMENT
  USER_SIGNATURE
  TEMP_UPLOAD
}

enum NotificationOutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum ProgressReminderKind {
  TASK_OVERDUE
  TASK_DUE_SOON
  TASK_PENDING_ACCEPTANCE_STALE
  WEEKLY_REPORT_MISSING
  TASK_STALE_ACTIVITY
  STAGE_STALE_OR_DUE_SOON
}

model User {
  id            String          @id @default(uuid())
  openId        String          @unique
  name          String
  avatar        String?
  signaturePath String?
  createdAt     DateTime        @default(now())
  orders        PurchaseOrder[]
}

model UserRole {
  id         String       @id @default(uuid())
  openId     String
  role       UserRoleType
  team       String       @default("")
  techGroup  String       @default("")

  @@unique([openId, role, team, techGroup])
}

model ProcurementBudgetPool {
  id                 String   @id @default(uuid())
  description        String   @default("")
  team               String
  techGroup          String
  period             String
  budgetAmount       Float
  lastAlertThreshold Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([team, techGroup, period])
}

model PurchaseOrder {
  id                String         @id @default(uuid())
  orderNo           String         @unique
  initiatorId       String
  initiator         User           @relation(fields: [initiatorId], references: [id])
  initiatorName     String
  team              String
  techGroup         String
  totalPrice        Float          @default(0)
  teamApproved            Boolean        @default(false)
  techGroupApproved       Boolean        @default(false)
  teamApproverOpenId      String?
  techGroupApproverOpenId String?
  invoicePaths      String         @default("[]")
  invoicePath       String?
  listDocPath       String?
  screenshotPath    String?
  status            OrderStatus    @default(DRAFT)
  isWorkshopFee     Boolean        @default(false)
  rejectionReason   String?
  rejectedAt        DateTime?
  rejectedByName    String?
  lastReminderAt    DateTime?
  statusEnteredAt   DateTime       @default(now())
  items             PurchaseItem[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

enum PurchaseItemKind {
  COMPONENT
  STANDARD_PART
  PROCESSING_FEE
}

model ProcessingVendor {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model PurchaseItem {
  id                 String            @id @default(uuid())
  orderId            String
  order              PurchaseOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name               String
  spec               String
  itemKind           PurchaseItemKind  @default(COMPONENT)
  purchaseLink       String            @default("")
  referenceImagePath String?
  processingVendor   String            @default("")
  quantity           Int
  unitPrice          Float
  photoPath          String?
  updatedAt          DateTime          @default(now()) @updatedAt
}

model Project {
  id            String              @id @default(uuid())
  name          String
  description   String              @default("")
  team          String
  techGroup     String
  status        ProjectStatus       @default(NOT_STARTED)
  ownerOpenId   String
  ownerName     String
  allowOwnerSelfApproval Boolean     @default(false)
  owners        ProjectOwner[]
  participants  ProjectParticipant[]
  stages        ProjectStage[]
  ddlChangeRequests ProjectDdlChangeRequest[]
  tasks         Task[]
  taskCreationRequests TaskCreationRequest[]
  activityLogs  ProgressActivityLog[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  archivedAt    DateTime?
  completedAt   DateTime?
  canceledAt    DateTime?
}

model ProjectOwner {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  openId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([projectId, openId])
}

model ProjectParticipant {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  openId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([projectId, openId])
}

model ProjectTemplate {
  id          String                 @id @default(uuid())
  name        String                 @unique
  description String                 @default("")
  /// Only one default template is enforced by the raw PostgreSQL partial unique index
  /// ProjectTemplate_single_default_idx in migrations/20260626220000_add_project_templates.
  isDefault   Boolean                @default(false)
  enabled     Boolean                @default(true)
  sortOrder   Int                    @default(0)
  stages      ProjectTemplateStage[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
}

model ProjectTemplateStage {
  id            String          @id @default(uuid())
  templateId    String
  template      ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name          String
  goal          String          @default("")
  dueOffsetDays Int
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([templateId, sortOrder])
}

model ProjectStage {
  id                  String           @id @default(uuid())
  projectId           String
  project             Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                String
  goal                String           @default("")
  sortOrder           Int
  status              StageStatus      @default(NOT_STARTED)
  evidenceUrl         String           @default("")
  ownerOpenId         String           @default("")
  ownerName           String           @default("")
  dueAt               DateTime?
  extensionCount      Int              @default(0)
  benignExtensionCount Int             @default(0)
  currentSubmissionId String?
  tasks               Task[]
  submissions         TaskSubmission[]
  ddlChangeRequests   ProjectDdlChangeRequest[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model ProjectDdlChangeRequest {
  id              String                        @id @default(uuid())
  projectId       String
  project         Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId         String
  stage           ProjectStage                  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  type            ProjectDdlChangeRequestType
  status          ProjectDdlChangeRequestStatus @default(PENDING)
  pendingKey      String                        @default("")
  requesterOpenId String
  requesterName   String
  reason          String
  oldDueAt        DateTime?
  newDueAt        DateTime?
  durationDays    Int?
  requestedIsBenign Boolean?
  finalIsBenign   Boolean?
  reviewerOpenId  String                        @default("")
  reviewerName    String                        @default("")
  reviewComment   String                        @default("")
  reviewedAt      DateTime?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt

  @@index([projectId, status])
  @@index([stageId, status])
  @@index([requesterOpenId])
  @@unique([stageId, pendingKey])
}

model Task {
  id              String              @id @default(uuid())
  projectId       String
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId         String?
  stage           ProjectStage?       @relation(fields: [stageId], references: [id], onDelete: SetNull)
  title           String
  goal            String              @default("")
  urgency         Urgency             @default(MEDIUM)
  importance      Importance          @default(MEDIUM)
  assigneeOpenId  String
  assigneeName    String
  assignees       TaskAssignee[]
  techGroups      TaskTechGroup[]
  team            String
  techGroup       String
  metrics         String              @default("")
  dueAt           DateTime
  status          TaskStatus          @default(TODO)
  isOverdue       Boolean             @default(false)
  needsOfflineConfirmation Boolean     @default(false)
  needsWeeklyReport Boolean            @default(false)
  riskNote        String              @default("")
  riskUpdatedAt   DateTime?
  failureReason   String              @default("")
  submissions     TaskSubmission[]
  weeklyReports   WeeklyReport[]
  activityLogs    ProgressActivityLog[]
  acceptanceChecklistItems TaskAcceptanceChecklistItem[]
  deletionRequests TaskDeletionRequest[]
  creationRequests TaskCreationRequest[]
  ddlChangeRequests TaskDdlChangeRequest[]
  riskRecords     TaskRiskRecord[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  archivedAt      DateTime?
  deletedAt       DateTime?
  deletedByOpenId String              @default("")
  deletedByName   String              @default("")
  deleteReason    String              @default("")
}

model TaskTechGroup {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  techGroup String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([taskId, techGroup])
  @@index([techGroup])
}

model TaskDeletionRequest {
  id              String                    @id @default(uuid())
  taskId          String
  task            Task                      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requesterOpenId String
  requesterName   String
  reason          String
  status          TaskDeletionRequestStatus @default(PENDING)
  pendingKey      String                    @default("")
  reviewerOpenId  String                    @default("")
  reviewerName    String                    @default("")
  reviewComment   String                    @default("")
  reviewedAt      DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([taskId, status])
  @@index([requesterOpenId])
  @@unique([taskId, pendingKey])
}

model TaskDdlChangeRequest {
  id              String                     @id @default(uuid())
  taskId          String
  task            Task                       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requesterOpenId String
  requesterName   String
  oldDueAt        DateTime
  newDueAt        DateTime
  reason          String
  status          TaskDdlChangeRequestStatus @default(PENDING)
  pendingKey      String                     @default("")
  reviewerOpenId  String                     @default("")
  reviewerName    String                     @default("")
  reviewComment   String                     @default("")
  reviewedAt      DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@index([taskId, status])
  @@index([requesterOpenId])
  @@unique([taskId, pendingKey])
}

model TaskCreationRequest {
  id              String                    @id @default(uuid())
  projectId       String
  project         Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requesterOpenId String
  requesterName   String
  draftPayload    String
  status          TaskCreationRequestStatus @default(PENDING)
  reviewerOpenId  String                    @default("")
  reviewerName    String                    @default("")
  reviewComment   String                    @default("")
  reviewedAt      DateTime?
  createdTaskId   String?
  createdTask     Task?                     @relation(fields: [createdTaskId], references: [id], onDelete: SetNull)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([projectId, status])
  @@index([requesterOpenId])
  @@index([createdTaskId])
}

model TaskRiskRecord {
  id               String         @id @default(uuid())
  taskId           String
  task             Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  content          String
  source           TaskRiskSource @default(MANUAL)
  status           TaskRiskStatus @default(ACTIVE)
  createdByOpenId  String
  createdByName    String
  resolvedByOpenId String         @default("")
  resolvedByName   String         @default("")
  resolveNote      String         @default("")
  resolvedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([taskId, status])
  @@index([createdByOpenId])
}

model TaskAssignee {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  openId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([taskId, openId])
}

model TaskSubmission {
  id            String           @id @default(uuid())
  taskId        String?
  task          Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectId     String?
  stageId       String?
  stage         ProjectStage?     @relation(fields: [stageId], references: [id], onDelete: Cascade)
  type          SubmissionType
  feishuDocUrl  String
  keyDataUrl    String           @default("") @map("videoUrl")
  note          String           @default("")
  failureReason String           @default("")
  submittedBy   String
  submitterName String
  submittedAt   DateTime         @default(now())
  approvals     ApprovalRecord[]
}

model AcceptanceChecklistTemplate {
  id        String   @id @default(uuid())
  content   String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskAcceptanceChecklistItem {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  content   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([taskId, sortOrder])
}

model WeeklyReport {
  id            String   @id @default(uuid())
  taskId        String
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  weekStart     DateTime
  progress      String
  nextPlan      String   @default("")
  feishuDocUrl  String   @default("")
  submittedBy   String
  submitterName String
  submittedAt   DateTime @default(now())

  @@unique([taskId, weekStart])
}

model ApprovalRecord {
  id              String           @id @default(uuid())
  submissionId    String
  submission      TaskSubmission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  approverOpenId  String
  approverName    String
  approverRole    UserRoleType
  decision        ApprovalDecision
  offlineConfirmed Boolean         @default(false)
  comment         String           @default("")
  checklistConfirmations ApprovalChecklistConfirmation[]
  createdAt       DateTime         @default(now())

  @@unique([submissionId])
}

model ApprovalChecklistConfirmation {
  id              String         @id @default(uuid())
  approvalId      String
  approval        ApprovalRecord @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  checklistItemId String
  content         String
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())

  @@index([approvalId, sortOrder])
}

model ProgressActivityLog {
  id         String   @id @default(uuid())
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  action     String
  actorOpenId String
  actorName  String
  payload    String   @default("{}")
  createdAt  DateTime @default(now())
}

model Feedback {
  id              String            @id @default(uuid())
  submitterOpenId String
  submitterName   String
  status          FeedbackStatus    @default(OPEN)
  lastMessageAt   DateTime          @default(now())
  closedAt        DateTime?
  messages        FeedbackMessage[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([submitterOpenId])
  @@index([status, lastMessageAt])
}

model FeedbackMessage {
  id           String               @id @default(uuid())
  feedbackId   String
  feedback     Feedback             @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  authorOpenId String
  authorName   String
  body         String               @default("")
  attachments  FeedbackAttachment[]
  createdAt    DateTime             @default(now())

  @@index([feedbackId, createdAt])
}

model FeedbackAttachment {
  id        String          @id @default(uuid())
  messageId String
  message   FeedbackMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  path      String
  fileName  String
  mimeType  String
  size      Int
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
}

model FileAsset {
  id                   String        @id @default(uuid())
  publicPath           String        @unique
  storagePath          String
  kind                 FileAssetKind
  mimeType             String
  size                 Int
  orderId              String?
  feedbackId           String?
  signatureOwnerOpenId String?
  ownerOpenId          String?
  createdAt            DateTime      @default(now())

  @@index([orderId])
  @@index([feedbackId])
  @@index([signatureOwnerOpenId])
  @@index([ownerOpenId])
}

model NotificationOutbox {
  id          String                   @id @default(uuid())
  eventKey    String                   @unique
  channel     String
  type        String
  payload     String
  status      NotificationOutboxStatus @default(PENDING)
  attempts    Int                      @default(0)
  lastError   String                   @default("")
  nextRunAt   DateTime                 @default(now())
  lockedUntil DateTime?
  sentAt      DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([status, nextRunAt])
}

model ProgressReminderRule {
  id                  String               @id @default(uuid())
  kind                ProgressReminderKind @unique
  enabled             Boolean              @default(true)
  scheduleTime        String               @default("09:00")
  paramsJson          String               @default("{}")
  recipientConfigJson String               @default("{}")
  lastRunAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}
