{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "scripts/**/*.ts",
    "prisma/seed.ts",
    "lib/**/*.ts",
    "prisma.config.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".tmp",
    "test-results",
    "playwright-report",
    "public/uploads",
    "storage/uploads"
  ]
}
