# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=management_system
POSTGRES_PORT=5432
DATABASE_URL="postgresql://postgres:replace-with-a-strong-password@localhost:5432/management_system"
SHADOW_DATABASE_URL="postgresql://postgres:replace-with-a-strong-password@localhost:5432/management_system_shadow"
# Playwright 默认使用 3100 端口和独立测试库；不要指向生产库。
PLAYWRIGHT_DATABASE_URL="postgresql://postgres:replace-with-a-strong-password@localhost:5432/management_system_test"
PLAYWRIGHT_BASE_URL="http://127.0.0.1:3100"

AUTH_SECRET="replace-with-openssl-rand-hex-32"
# 双入口访问时不要设置 AUTH_URL / NEXTAUTH_URL。
# Auth.js 会将它们视为唯一来源，导致域名和内网 IP 不能同时登录。
# 同一飞书应用凭证（OAuth + 机器人共用）
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
# 该应用机器人在通知群的 Webhook（出站消息）
FEISHU_WEBHOOK_URL=""
# 可选：Webhook 签名校验密钥
FEISHU_WEBHOOK_SECRET=""
# 可选：飞书通讯录人员同步频率（node-cron 表达式，默认每天 08:30）
FEISHU_CONTACT_SYNC_CRON="30 8 * * *"
NEXT_PUBLIC_APP_URL="https://pnx.demonmaster.cn"
APP_ALLOWED_ORIGINS="https://pnx.demonmaster.cn,http://10.4.150.222:3000,http://localhost:3000,http://127.0.0.1:3000"

# 局域网调试：手机/其他电脑访问时设置本机 IP，并在飞书后台添加对应重定向 URL
LAN_HOST=10.4.150.222
ALLOWED_DEV_ORIGINS=pnx.demonmaster.cn,10.4.150.222,localhost,127.0.0.1

# 全栈 Docker 部署（postgres + app + cron）见 docker-compose.yml
# RUN_DB_SEED=false
# 可选：宿主机没有 docker 组权限时，仅供 scripts/docker-compose-sudo.sh 调用 sudo。
# SUDO_PASSWORD=""
