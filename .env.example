# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=management_system
POSTGRES_PORT=5432
DATABASE_URL="postgresql://postgres:replace-with-a-strong-password@localhost:5432/management_system"
SHADOW_DATABASE_URL="postgresql://postgres:replace-with-a-strong-password@localhost:5432/management_system_shadow"
# Playwright 默认使用 3002 端口和独立测试库；不要指向生产库。
PLAYWRIGHT_DATABASE_URL="postgresql://postgres:replace-with-a-strong-password@localhost:5432/management_system_test"
PLAYWRIGHT_BASE_URL="http://127.0.0.1:3002"
# 仅手动执行 scripts/setup-playwright-db.ts 时需要；npm run test:e2e 会自动设置。
# PLAYWRIGHT_CONFIRM_RECREATE_DB="management_system_test"

AUTH_SECRET="replace-with-openssl-rand-hex-32"
# 双入口访问时不要设置 AUTH_URL / NEXTAUTH_URL。
# Auth.js 会将它们视为唯一来源，导致域名和内网 IP 不能同时登录。
# 飞书自建应用（OAuth 登录、通讯录同步、兼容默认消息应用）
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
# 普通通知机器人：普通私信、状态结果、提醒、反馈；未配置时回退 FEISHU_APP_ID/SECRET
FEISHU_NOTIFICATION_APP_ID=""
FEISHU_NOTIFICATION_APP_SECRET=""
# 审批通知机器人：仅发送审批/验收/确认待办；未配置时回退普通通知机器人
# 若审批机器人是独立应用，系统会使用 User.unionId 跨应用发送，需完成登录或通讯录同步。
FEISHU_APPROVAL_APP_ID=""
FEISHU_APPROVAL_APP_SECRET=""
# 可选：飞书私信收件人临时 allowlist，主要用于测试/演练防误发；为空表示不限制。
# 同时配置多个身份维度时，收件人必须在每个维度都匹配。
# Playwright 应用服务默认设置 FEISHU_DIRECT_MESSAGE_ALLOWED_NAMES="李棋轩"。
# FEISHU_DIRECT_MESSAGE_ALLOWED_NAMES="李棋轩"
# FEISHU_DIRECT_MESSAGE_ALLOWED_OPEN_IDS=""
# FEISHU_DIRECT_MESSAGE_ALLOWED_UNION_IDS=""
# 采购通知群 Webhook（未配置 FEISHU_PROCUREMENT_WEBHOOK_URL 时回退使用）
FEISHU_WEBHOOK_URL=""
FEISHU_PROCUREMENT_WEBHOOK_URL=""
# 可选：Webhook 签名校验密钥
FEISHU_WEBHOOK_SECRET=""
FEISHU_PROCUREMENT_WEBHOOK_SECRET=""
# 可选：事件订阅加密与校验（飞书后台「事件与回调」> 加密策略）
FEISHU_EVENT_ENCRYPT_KEY=""
FEISHU_VERIFICATION_TOKEN=""
# 可选：通知/审批机器人使用不同事件配置时覆盖；长连接用 FEISHU_WS_BOT_KIND 选择机器人
FEISHU_NOTIFICATION_EVENT_ENCRYPT_KEY=""
FEISHU_NOTIFICATION_VERIFICATION_TOKEN=""
FEISHU_APPROVAL_EVENT_ENCRYPT_KEY=""
FEISHU_APPROVAL_VERIFICATION_TOKEN=""
FEISHU_WS_BOT_KIND="notification"
# 生产 systemd 安装：审批机器人长连接默认开启；通知机器人长连接默认关闭。
# ENABLE_FEISHU_APPROVAL_WS=true
# ENABLE_FEISHU_WS=false
# 可选：飞书通讯录人员同步频率（node-cron 表达式，默认每天 08:30）
FEISHU_CONTACT_SYNC_CRON="30 8 * * *"
# 可选：每日进度摘要检查频率；每天 1–8 个实际发送时间由管理员面板「进度提醒 / 每日卡片」保存到数据库，默认 19:00。
PROGRESS_DAILY_SUMMARY_CHECK_CRON="*/5 * * * *"
# 兼容旧配置：仅在数据库中尚无每日卡片设置时，用简单每日表达式（如 "0 19 * * *"）推导首个发送时间。
# PROGRESS_DAILY_SUMMARY_CRON="0 19 * * *"
NEXT_PUBLIC_APP_URL="https://pnx.demonmaster.cn"
APP_ALLOWED_ORIGINS="https://pnx.demonmaster.cn,http://10.4.150.222:3000,http://localhost:3000,http://127.0.0.1:3000,http://localhost:3005,http://127.0.0.1:3005"
# 可选：在 3005 等独立端口开发时，飞书后台需添加对应重定向 URL，例如：
# http://localhost:3005/api/auth/callback/feishu
# http://127.0.0.1:3005/api/auth/callback/feishu
# 启动：npm run dev -- -p 3005
# 登录态与端口绑定，3000 的 cookie 不能用于 3005，需重新飞书登录或保存该端口的 Playwright storageState

# 局域网调试：手机/其他电脑访问时设置本机 IP，并在飞书后台添加对应重定向 URL
LAN_HOST=10.4.150.222
ALLOWED_DEV_ORIGINS=pnx.demonmaster.cn,10.4.150.222,localhost,127.0.0.1

# 全栈 Docker 部署（postgres + app + cron）见 docker-compose.yml
# RUN_DB_SEED=false
# 可选：上传目录。相对路径必须位于 storage/uploads 下；外部目录请使用绝对路径。
# UPLOAD_STORAGE_DIR="/absolute/path/to/uploads"
# 指导老师老师审核邮件（Microsoft 365 / Outlook SMTP）
SMTP_HOST="smtp.office365.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
# 可选：宿主机没有 docker 组权限时，仅供 scripts/docker-compose-sudo.sh 调用 sudo。
# SUDO_PASSWORD=""
