DATABASE_URL="file:./dev.db"
AUTH_SECRET="replace-with-openssl-rand-hex-32"
AUTH_URL="http://localhost:3000"
# 同一飞书应用凭证（OAuth + 机器人共用）
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
# 该应用机器人在通知群的 Webhook（出站消息）
FEISHU_WEBHOOK_URL=""
# 可选：Webhook 签名校验密钥
FEISHU_WEBHOOK_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 局域网调试（可选）：手机/其他电脑访问时改为本机 IP，并在飞书后台添加对应重定向 URL
# LAN_HOST=10.7.165.65
# AUTH_URL="http://10.7.165.65:3000"
# NEXT_PUBLIC_APP_URL="http://10.7.165.65:3000"
# ALLOWED_DEV_ORIGINS=10.7.165.65,192.168.1.100

# Docker 部署时 docker-compose 会覆盖为 file:/app/data/app.db，无需手动修改
# DATABASE_URL="file:/app/data/app.db"
# 首次部署写入 seed 角色：在 compose 中为 app 服务设置 RUN_DB_SEED=true（执行一次后改回 false）
# RUN_DB_SEED=false
